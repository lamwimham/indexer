{
  "name": "web3-indexer",
  "version": "1.0.0",
  "description": "Production-grade Web3 off-chain indexing service",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "web3",
    "blockchain",
    "indexer",
    "ethereum",
    "evm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.10.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "graphql": "^16.8.1",
    "ioredis": "^5.10.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.12.1",
    "prom-client": "^15.1.3",
    "viem": "^2.9.16",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@prisma/client": "^5.12.1",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^4.1.1",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
