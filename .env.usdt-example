# ===========================================
# Web3 Indexer - USDT Example Configuration
# ===========================================
# This example configures the indexer to track USDT (Tether) on Ethereum Mainnet

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (SQLite for development)
DATABASE_URL="file:./dev.db"

# Blockchain RPC
# Replace with your own RPC URL (Alchemy, Infura, QuickNode, etc.)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Chain ID (1 = Ethereum Mainnet)
CHAIN_ID=1

# Sync Configuration
# Start from USDT deployment block
START_BLOCK=4634748
# Batch size for fetching blocks
BATCH_SIZE=500
# Confirmations needed before considering block final
CONFIRMATIONS=12
# Sync interval in milliseconds
SYNC_INTERVAL=2000
# Max concurrent RPC requests
MAX_CONCURRENT_REQUESTS=10

# Contracts to index (JSON array)
# USDT on Ethereum Mainnet
CONTRACTS='[{"name":"USDT","address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","startBlock":4634748}]'