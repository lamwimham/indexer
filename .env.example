# ===========================================
# Web3 Indexer Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="file:./dev.db"

# Blockchain RPC
# Ethereum Mainnet
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# Or use public RPC (rate limited)
# RPC_URL=https://eth.llamarpc.com

# Chain ID (1 = Ethereum Mainnet, 5 = Goerli, 11155111 = Sepolia)
CHAIN_ID=1

# Sync Configuration
# Starting block (0 = deploy block of contract, or specific block)
START_BLOCK=0
# Batch size for fetching blocks
BATCH_SIZE=100
# Confirmations needed before considering block final
CONFIRMATIONS=12
# Sync interval in milliseconds
SYNC_INTERVAL=1000
# Max concurrent RPC requests
MAX_CONCURRENT_REQUESTS=5

# Contracts to index (JSON array)
# CONTRACTS='[{"name":"USDT","address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","startBlock":4634748}]'

# ===========================================
# Authentication (Optional)
# ===========================================
# Enable JWT authentication for API endpoints
AUTH_ENABLED=false
# JWT secret key (required if AUTH_ENABLED=true)
# JWT_SECRET=your-secret-key-here

# ===========================================
# Rate Limiting
# ===========================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true
# Max requests per time window
RATE_LIMIT_MAX=100
# Time window for rate limiting
RATE_LIMIT_WINDOW=1 minute

# ===========================================
# Redis (for distributed locking)
# ===========================================
# Redis connection URL (optional, for multi-instance deployments)
# REDIS_URL=redis://localhost:6379