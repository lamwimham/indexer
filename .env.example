# ===========================================
# Web3 Indexer Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="file:./dev.db"

# ===========================================
# Blockchain Configuration
# ===========================================

# Option 1: Single Chain (backward compatible)
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# CHAIN_ID=1

# Option 2: Multi-Chain (recommended for indexing multiple chains)
# CHAINS='[{"id":1,"name":"ethereum","rpcUrl":"https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY"},{"id":137,"name":"polygon","rpcUrl":"https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY"}]'

# Chain ID (used as fallback when CHAINS is not set)
CHAIN_ID=1

# Sync Configuration
# Starting block (0 = deploy block of contract, or specific block)
START_BLOCK=0
# Batch size for fetching blocks
BATCH_SIZE=100
# Confirmations needed before considering block final
CONFIRMATIONS=12
# Sync interval in milliseconds
SYNC_INTERVAL=1000
# Max concurrent RPC requests
MAX_CONCURRENT_REQUESTS=5

# ===========================================
# Contracts Configuration
# ===========================================

# Single chain contracts
# CONTRACTS='[{"name":"USDT","address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","startBlock":4634748}]'

# Multi-chain contracts (specify chainId for each contract)
# CONTRACTS='[{"name":"USDT-Ethereum","address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","chainId":1,"startBlock":4634748},{"name":"USDT-Polygon","address":"0xc2132D05D31c914a87C6611C10748AEb04B58e8F","chainId":137,"startBlock":25117600}]'

# ===========================================
# Authentication (Optional)
# ===========================================
# Enable JWT authentication for API endpoints
AUTH_ENABLED=false
# JWT secret key (required if AUTH_ENABLED=true)
# JWT_SECRET=your-secret-key-here

# ===========================================
# Rate Limiting
# ===========================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true
# Max requests per time window
RATE_LIMIT_MAX=100
# Time window for rate limiting
RATE_LIMIT_WINDOW=1 minute

# ===========================================
# Redis (for distributed locking)
# ===========================================
# Redis connection URL (optional, for multi-instance deployments)
# REDIS_URL=redis://localhost:6379