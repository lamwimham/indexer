# ===========================================
# Web3 Indexer 配置
# ===========================================

# 服务器配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# 数据库配置
DATABASE_URL="file:./dev.db"

# ===========================================
# 区块链配置
# ===========================================

# 选项 1：单链（向后兼容）
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# CHAIN_ID=1

# 选项 2：多链（推荐用于索引多条链）
# CHAINS='[{"id":1,"name":"ethereum","rpcUrl":"https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY"},{"id":137,"name":"polygon","rpcUrl":"https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY"}]'

# 链 ID（当未设置 CHAINS 时作为后备）
CHAIN_ID=1

# 同步配置
# 起始区块（0 = 合约部署区块，或指定区块号）
START_BLOCK=0
# 获取区块的批次大小
BATCH_SIZE=100
# 确认区块最终性所需的确认数
CONFIRMATIONS=12
# 同步间隔（毫秒）
SYNC_INTERVAL=1000
# 最大并发 RPC 请求数
MAX_CONCURRENT_REQUESTS=5

# ===========================================
# 合约配置
# ===========================================

# 单链合约
# CONTRACTS='[{"name":"USDT","address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","startBlock":4634748}]'

# 多链合约（为每个合约指定 chainId）
# CONTRACTS='[{"name":"USDT-Ethereum","address":"0xdAC17F958D2ee523a2206206994597C13D831ec7","chainId":1,"startBlock":4634748},{"name":"USDT-Polygon","address":"0xc2132D05D31c914a87C6611C10748AEb04B58e8F","chainId":137,"startBlock":25117600}]'

# ===========================================
# 认证配置（可选）
# ===========================================
# 为 API 端点启用 JWT 认证
AUTH_ENABLED=false
# JWT 密钥（如果 AUTH_ENABLED=true 则必需）
# JWT_SECRET=your-secret-key-here

# ===========================================
# 速率限制
# ===========================================
# 启用速率限制
RATE_LIMIT_ENABLED=true
# 时间窗口内最大请求数
RATE_LIMIT_MAX=100
# 速率限制时间窗口
RATE_LIMIT_WINDOW=1 minute

# ===========================================
# Redis（用于分布式锁）
# ===========================================
# Redis 连接 URL（可选，用于多实例部署）
# REDIS_URL=redis://localhost:6379